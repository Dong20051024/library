<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 管理后台</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/libseat.css" rel="stylesheet" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark navbar-admin">
            <div class="container">
                <a class="navbar-brand" asp-area="Admin" asp-controller="Reservation" asp-action="Index">⚙️ 管理后台</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="adminNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <span class="nav-link text-light">@Context.Session.GetString("AdminDisplayName")</span>
                        </li>
                        <li class="nav-item">
                            <form asp-area="Admin" asp-controller="Login" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="btn btn-outline-light btn-sm my-1">退出登录</button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-2 d-none d-md-block admin-sidebar">
                <div class="sidebar-logo">⚙️ 管理后台</div>
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Admin" asp-controller="Reservation" asp-action="Index">📋 预约管理</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Admin" asp-controller="Seat" asp-action="Index">💺 座位管理</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Admin" asp-controller="Statistics" asp-action="Index">📊 统计</a>
                    </li>
                    <li class="nav-item" style="margin-top: auto; border-top: 1px solid rgba(255,255,255,0.1);">
                        <a class="nav-link" asp-controller="Home" asp-action="Index" style="color: rgba(255,255,255,0.5) !important; font-size: 13px;">← 返回用户端</a>
                    </li>
                </ul>
            </nav>
            <script>
                // 当前页面高亮侧边栏菜单
                (function() {
                    var path = window.location.pathname.toLowerCase();
                    document.querySelectorAll('.admin-sidebar .nav-link').forEach(function(link) {
                        if (link.getAttribute('href') && path.indexOf(link.getAttribute('href').toLowerCase()) >= 0) {
                            link.classList.add('active');
                        }
                    });
                })();
            </script>
            <main class="col-md-10 p-4">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show">@TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show">@TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
