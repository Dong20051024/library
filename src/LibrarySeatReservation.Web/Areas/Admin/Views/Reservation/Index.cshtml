@model ReservationViewModel
@{
    ViewData["Title"] = "预约管理";
}

<h2 class="mb-4">预约管理</h2>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="get" class="row g-3 mb-4">
    <div class="col-auto">
        <select name="status" class="form-select" onchange="this.form.submit()">
            <option value="">全部状态</option>
            <option value="0" selected="@(Model.CurrentStatus == ReservationStatus.待签到)">待签到</option>
            <option value="1" selected="@(Model.CurrentStatus == ReservationStatus.使用中)">使用中</option>
            <option value="2" selected="@(Model.CurrentStatus == ReservationStatus.已完成)">已完成</option>
            <option value="3" selected="@(Model.CurrentStatus == ReservationStatus.已取消)">已取消</option>
        </select>
    </div>
</form>

@if (!Model.Items.Any())
{
    <div class="text-center py-5">
        <p class="text-muted">暂无预约记录</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-light">
                <tr>
                    <th>座位</th>
                    <th>楼层/区域</th>
                    <th>学生</th>
                    <th>时段</th>
                    <th>状态</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.SeatNumber</td>
                        <td>@item.Floor @item.Area</td>
                        <td>@item.StudentName</td>
                        <td>@item.StartTime.ToString("MM/dd HH:mm") — @item.EndTime.ToString("HH:mm")</td>
                        <td><span class="badge @item.StatusCssClass">@item.StatusText</span></td>
                        <td>
                            @if (item.CanCheckIn)
                            {
                                <form asp-area="Admin" asp-controller="Reservation" asp-action="CheckIn" asp-route-id="@item.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-success">签到</button>
                                </form>
                            }
                            @if (item.CanRelease)
                            {
                                <form asp-area="Admin" asp-controller="Reservation" asp-action="Release" asp-route-id="@item.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-warning">释放</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
